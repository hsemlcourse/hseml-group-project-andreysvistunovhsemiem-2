# Скопируйте файл в .env и заполните значения при необходимости.
# Любую переменную можно не задавать — будет использовано значение по умолчанию из src/config.py.

# Воспроизводимость
RANDOM_STATE=42

# Kaggle API (для скачивания датасета через kagglehub/kaggle CLI).
# Получить ключ: https://www.kaggle.com/settings -> Create New API Token
KAGGLE_USERNAME=
KAGGLE_KEY=

# Параметры сплита
TEST_SIZE=0.2
CV_SPLITS=5
